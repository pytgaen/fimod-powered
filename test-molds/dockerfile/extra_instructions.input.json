{
  "package_manager": "pip",
  "system_packages": ["curl"],
  "extra_instructions": {
    "runtime": {
      "after_os_update": [
        {"cp": {"certs/": "/usr/local/share/ca-certificates/"}},
        "RUN update-ca-certificates"
      ],
      "after_deps_install": [
        "RUN python -m spacy download fr_core_news_sm"
      ],
      "finalize": [
        "RUN python manage.py collectstatic --noinput"
      ]
    }
  },
  "expose": [8000],
  "cmd": ["gunicorn", "app:app"]
}
